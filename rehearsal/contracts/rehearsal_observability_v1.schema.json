{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "filin://contracts/rehearsal_observability_v1",
  "title": "Санитарный sample наблюдаемости локальной репетиции",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "sample_id", "component", "run_id", "sampled_at", "monotonic_ns", "health", "readiness", "cpu_percent", "normalized_cpu_percent", "rss_bytes", "vms_bytes", "file_descriptor_count", "thread_count", "process_count", "queue_depth", "journal_bytes", "wal_bytes", "storage_bytes", "backlog", "open_tls_connections", "tls_reconnect_count", "batch_size", "retry_count", "error_count"],
  "properties": {
    "contract_version": {"const": "rehearsal_observability_v1"},
    "sample_id": {"type": "string", "pattern": "^obs_[0-9a-f]{64}$"},
    "component": {"enum": ["traffic-source", "sensor-runtime", "staging-connector", "reference-receiver", "operator-view"]},
    "run_id": {"type": "string"},
    "sampled_at": {"type": "string", "format": "date-time"},
    "monotonic_ns": {"type": "integer", "minimum": 1},
    "health": {"type": "boolean"},
    "readiness": {"type": "boolean"},
    "cpu_percent": {"type": "number", "minimum": 0},
    "normalized_cpu_percent": {"type": "number", "minimum": 0},
    "rss_bytes": {"type": "integer", "minimum": 0},
    "vms_bytes": {"type": "integer", "minimum": 0},
    "file_descriptor_count": {"type": "integer", "minimum": 0},
    "thread_count": {"type": "integer", "minimum": 0},
    "process_count": {"type": "integer", "minimum": 0},
    "queue_depth": {"type": "integer", "minimum": 0},
    "journal_bytes": {"type": "integer", "minimum": 0},
    "wal_bytes": {"type": "integer", "minimum": 0},
    "storage_bytes": {"type": "integer", "minimum": 0},
    "backlog": {"type": "integer", "minimum": 0},
    "open_tls_connections": {"type": "integer", "minimum": 0},
    "tls_reconnect_count": {"type": "integer", "minimum": 0},
    "batch_size": {"type": "integer", "minimum": 0},
    "retry_count": {"type": "integer", "minimum": 0},
    "error_count": {"type": "integer", "minimum": 0}
  }
}
