{
  "$id": "https://filin.invalid/contracts/label_commitment_v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "committed_at_ns": {
      "minimum": 0,
      "type": "integer"
    },
    "holdout_id": {
      "pattern": "^[a-z0-9][a-z0-9_.:-]{2,127}$",
      "type": "string"
    },
    "label_count": {
      "minimum": 1,
      "type": "integer"
    },
    "labels_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "label_commitment_v1"
    }
  },
  "required": [
    "schema_version",
    "holdout_id",
    "labels_sha256",
    "label_count",
    "committed_at_ns"
  ],
  "title": "label_commitment_v1",
  "type": "object"
}
