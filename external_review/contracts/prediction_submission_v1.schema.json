{
  "$id": "https://filin.invalid/contracts/prediction_submission_v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate_commitment": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "holdout_id": {
      "pattern": "^[a-z0-9][a-z0-9_.:-]{2,127}$",
      "type": "string"
    },
    "predictions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "abstained": {
            "type": "boolean"
          },
          "episode_id": {
            "pattern": "^[a-z0-9][a-z0-9_.:-]{2,127}$",
            "type": "string"
          },
          "predicted_class": {
            "enum": [
              "benign",
              "auth_failures",
              "beacon",
              "low_rate_dos",
              "port_scan",
              "web_probe",
              null
            ]
          }
        },
        "required": [
          "episode_id",
          "predicted_class",
          "abstained"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "schema_version": {
      "const": "prediction_submission_v1"
    }
  },
  "required": [
    "schema_version",
    "holdout_id",
    "candidate_commitment",
    "predictions"
  ],
  "title": "prediction_submission_v1",
  "type": "object"
}
