{
  "$id": "https://filin.invalid/contracts/label_reveal_v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "holdout_id": {
      "pattern": "^[a-z0-9][a-z0-9_.:-]{2,127}$",
      "type": "string"
    },
    "label_commitment_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "labels": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "class": {
            "enum": [
              "benign",
              "auth_failures",
              "beacon",
              "low_rate_dos",
              "port_scan",
              "web_probe"
            ]
          },
          "episode_id": {
            "pattern": "^[a-z0-9][a-z0-9_.:-]{2,127}$",
            "type": "string"
          }
        },
        "required": [
          "episode_id",
          "class"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "prediction_commitment_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "revealed_at_ns": {
      "minimum": 0,
      "type": "integer"
    },
    "schema_version": {
      "const": "label_reveal_v1"
    }
  },
  "required": [
    "schema_version",
    "holdout_id",
    "label_commitment_sha256",
    "prediction_commitment_sha256",
    "revealed_at_ns",
    "labels"
  ],
  "title": "label_reveal_v1",
  "type": "object"
}
